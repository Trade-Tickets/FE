# =============================
# Frontend env for Backend API
# =============================

# Option A (recommended for deploy): set full backend URL
# Example local: http://localhost:8080
# Example prod : https://api.yourdomain.com
VITE_API_BASE_URL="http://localhost:8080"

# Option B (if VITE_API_BASE_URL is empty): app composes URL from protocol/host/port
VITE_API_PROTOCOL="http"
VITE_API_HOST="localhost"
VITE_API_PORT="8080"

# Sui wallet network (testnet | mainnet)
VITE_SUI_NETWORK="testnet"

# Optional explicit WebSocket base URL
# Example: ws://localhost:8080 or wss://api.yourdomain.com
# Leave empty to auto-derive from VITE_API_BASE_URL
VITE_WS_BASE_URL=""

# Existing keys
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
